# Supabase (existing)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Firebase — enable Phone sign-in in Firebase Console → Authentication → Sign-in method
# Add your web app host to Authentication → Settings → Authorized domains
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# FCM Web Push — Firebase Console → Project settings → Cloud Messaging → Web Push certificates (key pair)
VITE_FIREBASE_VAPID_KEY=

# reCAPTCHA Enterprise (Phone Auth) — Google Cloud → Security → reCAPTCHA Enterprise; same key linked in Firebase
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Vercel / production: add ALL of the above with the VITE_ prefix to the Production (and Preview if needed) env.
# Firebase Console → Authentication → Settings → Authorized domains: add your-host.vercel.app (and custom domain).
# Authentication → Settings → SMS: allow destination regions (e.g. India for +91). Phone SMS needs Blaze billing.

# Supabase Edge Function `send-push-notification`: set secret FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON of a
# Firebase service account with Firebase Cloud Messaging API access (Project settings → Service accounts → Generate key).
# When set, pushes use FCM; otherwise the function falls back to ONESIGNAL_REST_API_KEY if present.

# --- Supabase secrets (Dashboard → Edge Functions → Secrets), not Vite ---
# Same service account JSON as above is reused for reCAPTCHA Enterprise CreateAssessment when needed.
# RECAPTCHA_ENTERPRISE_SITE_KEY = same value as VITE_RECAPTCHA_ENTERPRISE_SITE_KEY (site key for assessments)
# Optional: RECAPTCHA_MIN_SCORE=0.35  REQUIRE_RECAPTCHA_FOR_SEND_OTP=true  RECAPTCHA_SERVICE_ACCOUNT_JSON=(alternate JSON)
