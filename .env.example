# Supabase (existing)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Firebase — enable Phone sign-in in Firebase Console → Authentication → Sign-in method
# Add your web app host to Authentication → Settings → Authorized domains
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# Vercel / production: add ALL of the above with the VITE_ prefix to the Production (and Preview if needed) env.
# Firebase Console → Authentication → Settings → Authorized domains: add your-host.vercel.app (and custom domain).
# Authentication → Settings → SMS: allow destination regions (e.g. India for +91). Phone SMS needs Blaze billing.
