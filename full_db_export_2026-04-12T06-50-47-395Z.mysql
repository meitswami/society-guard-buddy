-- ---------------------------------------------------------------------------
-- 20260412120000_superadmin_mfa_recovery.sql (MySQL)
-- ---------------------------------------------------------------------------

CREATE TABLE IF NOT EXISTS `super_admins` (
  `id` CHAR(36) NOT NULL,
  `username` TEXT NOT NULL,
  `password` TEXT NOT NULL,
  `name` TEXT NOT NULL,
  `created_at` DATETIME(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`id`),
  UNIQUE KEY `super_admins_username_key` (`username`(190))
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

ALTER TABLE `super_admins`
  ADD COLUMN IF NOT EXISTS `recovery_email` TEXT NULL,
  ADD COLUMN IF NOT EXISTS `totp_secret` TEXT NULL,
  ADD COLUMN IF NOT EXISTS `totp_enabled` TINYINT(1) NOT NULL DEFAULT 0;

UPDATE `super_admins`
SET
  `password` = 'Hello#123',
  `recovery_email` = 'meit8swami@gmail.com'
WHERE `username` = 'SUPERADMIN';

CREATE TABLE IF NOT EXISTS `superadmin_recovery_challenges` (
  `id` CHAR(36) NOT NULL,
  `super_admin_id` CHAR(36) NOT NULL,
  `code` TEXT NOT NULL,
  `expires_at` DATETIME(6) NOT NULL,
  `created_at` DATETIME(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`id`),
  KEY `idx_superadmin_recovery_super_admin` (`super_admin_id`),
  CONSTRAINT `superadmin_recovery_challenges_super_admin_id_fk`
    FOREIGN KEY (`super_admin_id`) REFERENCES `super_admins` (`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

-- ---------------------------------------------------------------------------
-- 20260412120000_fcm_web_tokens.sql (MySQL; trigger omitted — set updated_at in app)
-- ---------------------------------------------------------------------------

CREATE TABLE IF NOT EXISTS `fcm_web_tokens` (
  `id` CHAR(36) NOT NULL,
  `token` TEXT NOT NULL,
  `user_type` VARCHAR(32) NOT NULL,
  `app_user_id` TEXT NOT NULL,
  `flat_number` TEXT NULL,
  `society_id` CHAR(36) NULL,
  `updated_at` DATETIME(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`id`),
  UNIQUE KEY `fcm_web_tokens_token_unique` (`token`(255)),
  KEY `fcm_web_tokens_society_id_idx` (`society_id`),
  KEY `fcm_web_tokens_flat_number_idx` (`flat_number`(64)),
  KEY `fcm_web_tokens_user_idx` (`user_type`, `app_user_id`(128)),
  CONSTRAINT `fcm_web_tokens_user_type_chk`
    CHECK (`user_type` IN ('admin', 'guard', 'resident'))
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;

SET FOREIGN_KEY_CHECKS = 1;

