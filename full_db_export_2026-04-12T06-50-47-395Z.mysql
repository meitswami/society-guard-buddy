-- polls: 1 rows
INSERT INTO `polls` (`allow_multiple`, `created_at`, `created_by`, `description`, `end_date`, `id`, `is_active`, `question`, `society_id`) VALUES (0, '2026-04-12T04:36:25.547612+00:00', 'Administrator', 'सुरक्षा के दृष्टिगत, सभी सोसाइटी मेंबर्स से अनुरोध है कि प्लंबर, बढ़ई या अन्य किसी भी काम के लिए बाहरी व्यक्ति को घर बुलाने पर उन्हें अपने मालिक/कॉन्ट्रैक्टर को फोन कर पुष्टि करने के बाद ही परिसर में आने दें। संदिग्ध व्यक्ति की सूचना तुरंत सुरक्षा गार्ड या समिति को दें।गार्ड आपसे फोन पर बात होने के बाद ही फ्लैट मैं आने देगा,सभी सोसाइटी सदस्य इसमें सहयोग करे।', NULL, 'eee4821b-9d82-412e-82d7-a1ffb33beff2', 1, 'Due to Security Reasons outsider people for any flat maintainance work.', NULL);

